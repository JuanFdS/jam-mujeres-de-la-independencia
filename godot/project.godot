[internationalization]

locale/translations=PackedStringArray("res://i18n/translation.de.translation", "res://i18n/translation.en.translation")

[layer_names]

3d_physics/layer_1="terrain"
3d_physics/layer_2="player"
3d_physics/layer_3="enemy"
3d_physics/layer_4="block_player_only"
3d_physics/layer_5="floor_for_camera"
3d_physics/layer_6="destructible"

[physics]

3d/default_gravity=4.899999999999999

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/size=1024
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=0
environment/defaults/default_clear_color=Color(0.211765, 0.239216, 0.321569, 1)
